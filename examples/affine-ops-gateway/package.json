{
  "name": "@rta/example-affine-ops-gateway",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:coverage": "pnpm test:coverage && pnpm --filter @rta/cli build && pnpm --filter @rta/cli rta check --coverage-waivers --root ../../examples/affine-ops-gateway",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "^3.0.0"
  },
  "devDependencies": {
    "@rta/cli": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  }
}
