{
  "name": "meeting-digest",
  "vocabulary": [
    {
      "id": "TranscriptInput",
      "extends": "T1.Input",
      "description": "Concrete meeting transcript input accepted by bulk or simulated streaming mode."
    },
    {
      "id": "TopicSegmenter",
      "extends": "T2.Pattern.TopicSegmentation",
      "description": "Concrete topic accumulator that can append loopbacks instead of duplicating topics."
    },
    {
      "id": "WorkItemExtractor",
      "extends": "T2.Pattern.TaskExtraction",
      "description": "Concrete extractor for feature, automation, and research work."
    },
    {
      "id": "ReviewableDigestJob",
      "extends": "T3.Archetype.JobProcessor",
      "description": "Concrete job processor that produces digest artifacts and review queue items."
    },
    {
      "id": "DigestArtifact",
      "extends": "T1.Artifact",
      "description": "Concrete JSON and Markdown digest artifacts written for review."
    }
  ],
  "useCases": [
    {
      "id": "DigestTranscriptForReview",
      "actor": "operator reviewing meeting output",
      "goal": "Turn a transcript into topics and extracted work items for QA/demo review.",
      "scenarios": ["meeting-digest.v2.fixture"]
    },
    {
      "id": "ApproveAndDryRunPublishDigest",
      "actor": "operator",
      "goal": "Approve a review item and publish only to a dry-run adapter.",
      "scenarios": ["meeting-digest.v2.fixture"]
    },
    {
      "id": "ProcessStreamingTopicBatch",
      "actor": "operator in or just after a meeting",
      "goal": "Process stream-like topic batches while preserving loopback context.",
      "scenarios": ["meeting-digest.streaming.fixture", "meeting-digest.loopback.fixture"]
    },
    {
      "id": "ExtractReviewableWorkItemSpecs",
      "actor": "operator preparing work for QA",
      "goal": "Produce reviewable task specs with goals, users, systems, integrations, and classification.",
      "scenarios": ["approved-digest-publishes-work-items"]
    },
    {
      "id": "RespectUnavailableEnrichment",
      "actor": "operator relying on transcript-only context",
      "goal": "Declare when AFFiNE/local enrichment is unavailable instead of hallucinating context.",
      "scenarios": ["meeting-digest.enrichment-unavailable.fixture"]
    }
  ],
  "scenarios": [
    {
      "id": "meeting-digest.v1.fixture",
      "mode": "bulk",
      "coversVocabulary": ["TranscriptInput"],
      "expectedArtifacts": ["meeting-digest-v1.json"]
    },
    {
      "id": "meeting-digest.v2.fixture",
      "mode": "bulk",
      "coversVocabulary": ["TranscriptInput", "TopicSegmenter", "WorkItemExtractor", "ReviewableDigestJob", "DigestArtifact"],
      "expectedArtifacts": ["meeting-digest-v2.json", "logs.json", "provenance.json"]
    },
    {
      "id": "meeting-digest.integrated.fixture",
      "mode": "bulk",
      "coversVocabulary": ["TranscriptInput", "TopicSegmenter", "WorkItemExtractor", "ReviewableDigestJob", "DigestArtifact"],
      "expectedArtifacts": ["meeting-digest-integrated.json", "meeting-digest-integrated.md", "logs.json", "provenance.json"]
    },
    {
      "id": "meeting-digest.streaming.fixture",
      "mode": "simulated-stream",
      "coversVocabulary": ["TranscriptInput", "TopicSegmenter", "WorkItemExtractor", "ReviewableDigestJob", "DigestArtifact"],
      "expectedArtifacts": ["meeting-digest-streaming.json", "meeting-digest-streaming.md", "logs.json", "provenance.json"]
    },
    {
      "id": "meeting-digest.loopback.fixture",
      "mode": "bulk",
      "coversVocabulary": ["TranscriptInput", "TopicSegmenter", "WorkItemExtractor", "ReviewableDigestJob", "DigestArtifact"],
      "expectedArtifacts": ["meeting-digest-loopback.json", "meeting-digest-loopback.md", "logs.json", "provenance.json"]
    },
    {
      "id": "meeting-digest.enrichment-unavailable.fixture",
      "mode": "bulk",
      "coversVocabulary": ["TranscriptInput", "TopicSegmenter", "WorkItemExtractor", "ReviewableDigestJob", "DigestArtifact"],
      "expectedArtifacts": ["meeting-digest-enrichment-unavailable.json", "meeting-digest-enrichment-unavailable.md", "logs.json", "provenance.json"]
    },
    {
      "id": "approved-digest-publishes-work-items",
      "mode": "bulk",
      "coversVocabulary": ["TranscriptInput", "TopicSegmenter", "WorkItemExtractor", "ReviewableDigestJob", "DigestArtifact"],
      "expectedArtifacts": ["approved-digest-publishes-work-items.json", "approved-digest-publishes-work-items.md", "approved-digest-work-items.json", "logs.json", "provenance.json"]
    }
  ],
  "boundaries": [
    {
      "from": "ingestion",
      "to": "topic-segmentation",
      "coveredBy": ["meeting-digest.v2.fixture"]
    },
    {
      "from": "topic-segmentation",
      "to": "task-extraction",
      "coveredBy": ["meeting-digest.v2.fixture"]
    },
    {
      "from": "review",
      "to": "publication",
      "coveredBy": ["meeting-digest.v2.fixture", "approved-digest-publishes-work-items"]
    },
    {
      "from": "topic-segmentation",
      "to": "enrichment",
      "coveredBy": ["meeting-digest.enrichment-unavailable.fixture"]
    },
    {
      "from": "streaming-intake",
      "to": "topic-segmentation",
      "coveredBy": ["meeting-digest.streaming.fixture"]
    }
  ],
  "logging": {
    "humanReadableTemplate": "[{runId}] {step} actor={actor} input={input} output={output}",
    "ceremonies": [
      {
        "for": "TranscriptInput",
        "operation": "TranscriptInput.read",
        "requiredEvents": ["start", "complete", "failed"],
        "summaries": ["input", "output"],
        "detailAt": ["high", "trace"]
      },
      {
        "for": "TranscriptInput",
        "operation": "TranscriptInput.parse",
        "requiredEvents": ["start", "complete", "failed"],
        "summaries": ["input", "output"],
        "detailAt": ["high", "trace"]
      },
      {
        "for": "TopicSegmenter",
        "operation": "TopicSegmenter.segment",
        "requiredEvents": ["start", "complete", "failed"],
        "summaries": ["input", "output"],
        "detailAt": ["high", "trace"]
      },
      {
        "for": "WorkItemExtractor",
        "operation": "WorkItemExtractor.extract",
        "requiredEvents": ["start", "complete", "failed"],
        "summaries": ["input", "output"],
        "detailAt": ["high", "trace"]
      },
      {
        "for": "ReviewableDigestJob",
        "operation": "ReviewableDigestJob.materialize",
        "requiredEvents": ["start", "complete", "failed"],
        "summaries": ["input", "output"],
        "detailAt": ["high", "trace"]
      },
      {
        "for": "DigestArtifact",
        "operation": "DigestArtifact.write",
        "requiredEvents": ["start", "complete", "failed"],
        "summaries": ["input", "output"],
        "detailAt": ["high", "trace"]
      }
    ]
  },
  "publication": {
    "requiresReview": true,
    "adapters": ["dry-run-fixture"],
    "connectorPolicies": [
      {
        "id": "dry-run-fixture",
        "mode": "dry-run",
        "dataSensitivity": "internal",
        "externalWrites": false,
        "requiresReview": true,
        "allowedTargets": ["fixture"]
      }
    ]
  },
  "security": {
    "inputPathPolicy": "repo-contained",
    "redactSecrets": true,
    "externalWritesRequireReview": true
  }
}
